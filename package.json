{
  "name": "zmarketplace",
  "version": "0.7.8",
  "description": "Cross-agent marketplace search: find, audit, and install plugins/skills/themes/prompts across pi, omp, claude code, opencode, gemini cli, and codex",
  "license": "MIT",
  "author": {
    "name": "zico20047"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zico20047/zmarketplace.git"
  },
  "homepage": "https://github.com/zico20047/zmarketplace",
  "type": "module",
  "bin": {
    "zmarketplace": "./src/cli.ts"
  },
  "files": [
    "src",
    "README.md",
    ".claude-plugin",
    ".codex-plugin",
    "gemini-extension.json"
  ],
  "keywords": [
    "pi-package",
    "claude-code",
    "opencode",
    "gemini-cli",
    "codex",
    "npm",
    "marketplace",
    "plugin",
    "search",
    "install",
    "audit"
  ],
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "omp": {
    "extensions": ["./src/index.ts"]
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/opencode.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun run test/full-test.ts",
    "test:unit": "bun run test/unit/cache.test.ts && bun run test/unit/history.test.ts && bun run test/unit/installed.test.ts && bun run test/unit/tar.test.ts"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/bun": "^1.3.14"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
